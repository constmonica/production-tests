name: ShellCheck

on:
  push:
    branches: [reorganize_tests]
    pull_request: [reorganize_tests]

jobs:
  shellcheck:
    name: ShellCheck
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Run ShellCheck
        uses: ludeeus/action-shellcheck@master
        with:
          scandir: './main_tests'
          severity: error
